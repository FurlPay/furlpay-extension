{
  "name": "@furlpay/extension",
  "version": "1.0.0",
  "private": true,
  "description": "FurlPay browser extension (MV3) — x402 payments, biometric 3DS approvals, travel agent, fee scanner, and the x402 DevTools inspector.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "shell-quote": ">=1.8.4",
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1",
    "esbuild": ">=0.28.1"
  },
  "devDependencies": {
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "^5.9.3",
    "wxt": "^0.20.6"
  }
}
